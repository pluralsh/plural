{
  "name": "www",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --mode staging",
    "preview": "vite preview",
    "analyze": "tsc && ANALYZE=true vite build",
    "start": "vite",
    "start:dev-api": "vite --mode dev-api",
    "start:prod": "yarn build:staging && serve -s -p 3001 build",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "concurrently \"yarn lint:format\" \"yarn lint:js\" \"yarn lint:css\"",
    "lint:format": "prettier --check ./src",
    "lint:js": "eslint ./src",
    "lint:css": "stylelint src/**/*.css",
    "fix": "yarn fix:format && yarn fix:js && yarn fix:css",
    "fix:format": "prettier --write ./src",
    "fix:js": "eslint ./src --fix",
    "fix:css": "stylelint src/**/*.css --fix",
    "unimported": "npx unimported",
    "graphql:codegen": "graphql-codegen --config codegen.yml",
    "postinstall": "node ./scripts/husky-install.cjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@4.17.1",
